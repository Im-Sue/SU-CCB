{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://su-ccb.local/schemas/role-profile-v0.1.json",
  "title": "CCB RoleProfile v0.1",
  "description": "Reference-only role profile contract. v0.1 binds a named role to an ExecutorProfile and a prompt_template_ref string without invoking, rendering, or checking template file existence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "name",
    "executor_profile_id",
    "prompt_template_ref",
    "variable_overrides"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "role-profile-v0.1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "executor_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_template_ref": {
      "type": "string",
      "pattern": "^docs/\\.ccb/templates/prompts/[^/]+\\.md$"
    },
    "variable_overrides": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
